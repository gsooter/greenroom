# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback/spotify

# Tidal (music-service connect — Phase 5)
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_REDIRECT_URI=http://localhost:3000/api/auth/callback/tidal

# Apple Music (music-service connect — Phase 5)
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=
APPLE_MUSIC_PRIVATE_KEY_PATH=
APPLE_MUSIC_BUNDLE_ID=

# Apple Maps (MapKit JS + Snapshot + Maps Server API)
# Variable prefix is APPLE_MAPKIT_ (not APPLE_MAPS_) — mirrors the
# Settings field names in backend/core/config.py.
APPLE_MAPKIT_TEAM_ID=
APPLE_MAPKIT_KEY_ID=
APPLE_MAPKIT_PRIVATE_KEY=
APPLE_MAPKIT_PRIVATE_KEY_PATH=

# Knuckles identity service
KNUCKLES_URL=
KNUCKLES_CLIENT_ID=
KNUCKLES_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://greenroom:greenroom@localhost:5432/greenroom

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRY_SECONDS=3600

# Resend
# Sender should be a Greenroom-branded address whose domain has
# SPF/DKIM/DMARC records configured and verified in Resend. Format
# ``Display Name <local@domain>`` is supported by Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Svix-style ``whsec_...`` webhook signing secret. Set after creating
# the webhook in the Resend dashboard; empty in dev disables the
# bounce-handling endpoint at /api/v1/webhooks/resend.
RESEND_WEBHOOK_SECRET=

# Web Push (VAPID) — required for browser push notifications. Generate
# the keypair with ``py-vapid --gen --applicationServerKey`` or the
# equivalent ``web-push generate-vapid-keys`` from the npm tool. The
# public key is exposed to the frontend; the private key stays on the
# server. ``VAPID_SUBJECT`` is a ``mailto:`` URI per the Web Push spec
# and should match RESEND_FROM_EMAIL's domain.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Ticketmaster
TICKETMASTER_API_KEY=

# SeatGeek
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=

# Admin
ADMIN_SECRET_KEY=change-me-in-production

# Alerting — three Slack channels, one webhook each. Categories
# without their own URL fall back to the ops webhook, so a single-
# webhook deployment still receives every alert.
SLACK_WEBHOOK_OPS_URL=
SLACK_WEBHOOK_DIGEST_URL=
SLACK_WEBHOOK_FEEDBACK_URL=
ALERT_EMAIL=

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=
